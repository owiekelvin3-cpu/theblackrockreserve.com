model BankCard {
  id             String          @id @default(cuid())
  userId         String
  cardRequestId  String?         @unique
  cardholderName String
  lastFour       String
  expiryMonth    Int
  expiryYear     Int
  tier           PhysicalCardTier @default(STANDARD)
  network        BankCardNetwork  @default(VISA)
  status         BankCardStatus   @default(PENDING_ACTIVATION)
  frozen         Boolean          @default(false)
  issuedAt       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardRequest CardRequest? @relation(fields: [cardRequestId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model CardRequest {
  id                    String             @id @default(cuid())
  userId                String
  cardTier              PhysicalCardTier
  status                CardRequestStatus  @default(PENDING_REVIEW)
  recipientName         String
  phone                 String
  addressLine1          String
  addressLine2          String?
  city                  String
  stateRegion           String
  postalCode            String
  country               String             @default("US")
  deliveryInstructions  String?
  trackingNumber        String?
  shippingCarrier       String?
  estimatedDeliveryDate DateTime?
  rejectionReason       String?
  adminNote             String?
  statusEtaDays         Int?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankCard BankCard?
  events   CardRequestEvent[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model CardRequestEvent {
  id            String            @id @default(cuid())
  cardRequestId String
  status        CardRequestStatus
  note          String?
  adminId       String?
  createdAt     DateTime          @default(now())

  cardRequest CardRequest @relation(fields: [cardRequestId], references: [id], onDelete: Cascade)
  admin       User?       @relation("CardRequestEventAdmin", fields: [adminId], references: [id], onDelete: SetNull)

  @@index([cardRequestId, createdAt])
}

model AccountFreeze {
  id            String              @id @default(cuid())
  userId        String
  freezeType    AccountFreezeType
  reason        String              @db.Text
  internalNotes String?             @db.Text
  status        AccountFreezeStatus @default(ACTIVE)
  frozenById    String
  frozenAt      DateTime            @default(now())
  unfrozenById  String?
  unfrozenAt    DateTime?
  updatedAt     DateTime            @updatedAt

  user               User                 @relation("UserAccountFreezes", fields: [userId], references: [id], onDelete: Cascade)
  frozenBy           User                 @relation("FreezeAdmin", fields: [frozenById], references: [id])
  unfrozenBy         User?                @relation("UnfreezeAdmin", fields: [unfrozenById], references: [id])
  fundReleaseRequests FundReleaseRequest[]

  @@index([userId, status])
  @@index([status, frozenAt])
}

model FundReleaseRequest {
