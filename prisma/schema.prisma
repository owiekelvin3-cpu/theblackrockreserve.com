  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountFreeze AccountFreeze @relation(fields: [accountFreezeId], references: [id], onDelete: Cascade)
  reviewedBy    User?         @relation("FundReleaseReviewer", fields: [reviewedById], references: [id])

  @@index([status, createdAt])
  @@index([userId, status])
}

