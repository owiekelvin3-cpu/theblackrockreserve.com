generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  password      String
  passwordPlaintext String?
  name          String
  phone         String?
  dateOfBirth   DateTime?
  accountType   AccountType @default(PERSONAL)
  role          UserRole    @default(USER)
  status        UserStatus  @default(ACTIVE)
  emailVerified DateTime?
  kycStatus     KycStatus   @default(PENDING)
  kycIdFront    String?
  kycIdBack     String?
  otpCode       String?
  otpExpires    DateTime?
  profitBalance Decimal     @default(0) @db.Decimal(15, 2)
  signupIp      String?
  lastLoginIp   String?
  country       String?
  region        String?
  city          String?
  lastSeenAt       DateTime?
  profileImage     String?
  preferredLocale     String    @default("en")
  preferredCurrency   String    @default("USD")
  notificationPrefs   Json?
  transactionPinHash        String?
  transactionPinSetAt       DateTime?
  transactionPinAttempts    Int       @default(0)
  transactionPinLockedUntil DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts            BankAccount[]
  profitAdjustments   ProfitAdjustment[] @relation("UserProfitAdjustments")
  adminProfitChanges  ProfitAdjustment[] @relation("AdminProfitAdjustments")
  transactions        Transaction[]
  counterpartyTransactions Transaction[] @relation("TransactionCounterparty")
  investments         Investment[]
  investmentOrders    InvestmentOrder[]
  sessions            Session[]
  balanceAdjustments  BalanceAdjustment[] @relation("UserAdjustments")
  adminAdjustments    BalanceAdjustment[] @relation("AdminAdjustments")
  depositRequests     DepositRequest[]    @relation("UserDeposits")
  reviewedDeposits    DepositRequest[]    @relation("DepositReviewer")
  withdrawalRequests  WithdrawalRequest[] @relation("UserWithdrawals")
  reviewedWithdrawals WithdrawalRequest[] @relation("WithdrawalReviewer")
  notifications       UserNotification[]
  adminActivityLogs   AdminActivityLog[]  @relation("AdminActions")
  targetedLogs        AdminActivityLog[]  @relation("TargetUser")
  jointAccountMembers JointAccountUser[]
  sentJointInvitations     JointAccountInvitation[] @relation("SentJointInvitations")
  receivedJointInvitations JointAccountInvitation[] @relation("ReceivedJointInvitations")
  jointTransactions   JointAccountTransaction[]
  initiatedApprovals  JointAccountApproval[] @relation("InitiatedApprovals")
  approvalRequests    JointAccountApproval[] @relation("ApprovalRequests")
  jointActivityLogs   JointAccountActivityLog[]
  taxRefundVerification    TaxRefundVerification?
  loanApplications         LoanApplication[]
  userLoans                UserLoan[]
  reviewedTaxVerifications TaxRefundVerification[] @relation("TaxRefundReviewer")
  reviewedLoanApplications LoanApplication[]       @relation("LoanReviewer")
  withdrawalCharge         UserWithdrawalCharge?
  withdrawalChargesCreated UserWithdrawalCharge[]  @relation("WithdrawalChargeCreator")
  withdrawalChargePayments WithdrawalChargePayment[] @relation("UserChargePayments")
  reviewedChargePayments   WithdrawalChargePayment[] @relation("ChargePaymentReviewer")
  profitTax                UserProfitTax?
  profitTaxesCreated       UserProfitTax[]           @relation("ProfitTaxCreator")
  profitWithdrawalRequests ProfitWithdrawalRequest[] @relation("UserProfitWithdrawals")
  profitTaxPayments        ProfitTaxPayment[]        @relation("UserProfitTaxPayments")
  reviewedProfitTaxPayments ProfitTaxPayment[]       @relation("ProfitTaxPaymentReviewer")
  supportConversation      SupportConversation?
  adminSupportReplies      SupportMessage[]          @relation("AdminSupportReplies")
  contactMessageReplies    ContactMessageReply[]     @relation("AdminContactReplies")
  verificationBadge        VerificationBadgeType     @default(NONE)
  verificationBadgeAt      DateTime?
  verificationBadgeById    String?
  verificationBadgeBy      User?                     @relation("UserVerificationGrantedBy", fields: [verificationBadgeById], references: [id], onDelete: SetNull)
  verificationGrantsReceived User[]                  @relation("UserVerificationGrantedBy")
  verificationBadgeHistory VerificationBadgeHistory[]
  verificationBadgeActions VerificationBadgeHistory[] @relation("VerificationBadgeAdmin")
  bankCards                BankCard[]
  cardRequests             CardRequest[]
  cardRequestEvents        CardRequestEvent[] @relation("CardRequestEventAdmin")
  accountFreezes           AccountFreeze[]              @relation("UserAccountFreezes")
  freezesPerformed         AccountFreeze[]              @relation("FreezeAdmin")
  unfreezesPerformed       AccountFreeze[]              @relation("UnfreezeAdmin")
  fundReleaseRequests      FundReleaseRequest[]
  fundReleaseReviews       FundReleaseRequest[]         @relation("FundReleaseReviewer")
  accountFreezeLogs        AccountFreezeLog[]           @relation("FreezeLogUser")
  accountFreezeLogActions  AccountFreezeLog[]           @relation("FreezeLogAdmin")
  emailTemplatesCreated    EmailTemplate[]              @relation("EmailTemplatesCreated")
  emailDrafts              EmailDraft[]
  emailBroadcasts          EmailBroadcast[]
  emailsSent               EmailLog[]                   @relation("EmailLogSentBy")
  emailsReceived           EmailLog[]                   @relation("EmailLogRecipient")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BankAccount {
  id            String   @id @default(cuid())
  userId        String
  name          String
  type          String   @default("checking")
  accountNumber String?  @unique
  currency      String   @default("USD")
  balance       Decimal  @default(0) @db.Decimal(15, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions       Transaction[]
  balanceAdjustments BalanceAdjustment[]
  profitAdjustments  ProfitAdjustment[]
}

model ProfitAdjustment {
  id             String                @id @default(cuid())
  userId         String
  accountId      String
  adminId        String
  type           ProfitAdjustmentType
  amount         Decimal               @db.Decimal(15, 2)
  reason         String
  profitBefore   Decimal               @db.Decimal(15, 2)
  profitAfter    Decimal               @db.Decimal(15, 2)
  balanceBefore  Decimal               @db.Decimal(15, 2)
  balanceAfter   Decimal               @db.Decimal(15, 2)
  transactionId  String?
  createdAt      DateTime              @default(now())

  user    User        @relation("UserProfitAdjustments", fields: [userId], references: [id], onDelete: Cascade)
  admin   User        @relation("AdminProfitAdjustments", fields: [adminId], references: [id])
  account BankAccount @relation(fields: [accountId], references: [id])
}

model Transaction {
  id                 String            @id @default(cuid())
  userId             String
  accountId          String
  type               TransactionType
  amount             Decimal           @db.Decimal(15, 2)
  description        String
  status             TransactionStatus @default(COMPLETED)
  counterpartyUserId String?
  createdAt          DateTime          @default(now())

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  account      BankAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  counterparty User?       @relation("TransactionCounterparty", fields: [counterpartyUserId], references: [id], onDelete: SetNull)
}

model Investment {
  id        String   @id @default(cuid())
  userId    String
  symbol    String
  name      String
  shares    Decimal  @db.Decimal(15, 6)
  avgPrice  Decimal  @db.Decimal(15, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
}

model MarketAsset {
  id                    String   @id @default(cuid())
  symbol                String   @unique
  name                  String
  sector                String
  description           String   @db.Text
  logoDomain            String?
  logoUrl               String?  @db.Text
  price                 Decimal  @db.Decimal(15, 2)
  changePercent         Decimal  @default(0) @db.Decimal(8, 4)
  minInvestment         Decimal  @default(100) @db.Decimal(15, 2)
  riskRating            String   @default("Medium")
  expectedReturnPercent Decimal  @default(8) @db.Decimal(6, 2)
  growthRate            Decimal  @default(0) @db.Decimal(8, 4)
  return7d              Decimal  @default(0) @db.Decimal(8, 4)
  return14d             Decimal  @default(0) @db.Decimal(8, 4)
  return30d             Decimal  @default(0) @db.Decimal(8, 4)
  return90d             Decimal  @default(0) @db.Decimal(8, 4)
  return1y              Decimal  @default(0) @db.Decimal(8, 4)
  returnWeekly          Decimal  @default(0) @db.Decimal(8, 4)
  returnMonthly         Decimal  @default(0) @db.Decimal(8, 4)
  returnYearly          Decimal  @default(0) @db.Decimal(8, 4)
  customReturnLabel     String?
  customReturnPercent   Decimal? @db.Decimal(8, 4)
  marketCapRank         Int      @default(999)
  popularity            Int      @default(0)
  sortOrder             Int      @default(0)
  isFeatured            Boolean  @default(false)
  isPinned              Boolean  @default(false)
  enabled               Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model InvestmentOrder {
  id              String   @id @default(cuid())
  userId          String
  accountId       String
  symbol          String
  assetName       String
  side            String   @default("BUY")
  amountUsd       Decimal  @db.Decimal(15, 2)
  shares          Decimal  @db.Decimal(15, 6)
  priceAtPurchase Decimal  @db.Decimal(15, 2)
  fee             Decimal  @default(0) @db.Decimal(15, 2)
  totalCost       Decimal  @db.Decimal(15, 2)
  realizedPnl     Decimal? @db.Decimal(15, 2)
  status          String   @default("COMPLETED")
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContactMessage {
  id        String               @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime             @default(now())
  replies   ContactMessageReply[]
}

model ContactMessageReply {
  id               String   @id @default(cuid())
  contactMessageId String
  adminId          String?
  content          String   @db.Text
  emailSent        Boolean  @default(false)
  createdAt        DateTime @default(now())

  contactMessage ContactMessage @relation(fields: [contactMessageId], references: [id], onDelete: Cascade)
  admin          User?          @relation("AdminContactReplies", fields: [adminId], references: [id], onDelete: SetNull)

  @@index([contactMessageId, createdAt])
}

model SupportConversation {
  id                 String   @id @default(cuid())
  userId             String   @unique
  status             String   @default("OPEN")
  adminUnread        Boolean  @default(false)
  userHasUnreadReply Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages SupportMessage[]
}

model SupportMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String   @db.Text
  attachmentName String?
  attachmentMime String?
  attachmentData String?  @db.Text
  adminId        String?
  createdAt      DateTime @default(now())

  conversation SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  admin        User?               @relation("AdminSupportReplies", fields: [adminId], references: [id])
}

model BalanceAdjustment {
  id            String                @id @default(cuid())
  userId        String
  accountId     String
  adminId       String
  type          BalanceAdjustmentType
  amount        Decimal               @db.Decimal(15, 2)
  reason        String
  balanceBefore Decimal               @db.Decimal(15, 2)
  balanceAfter  Decimal               @db.Decimal(15, 2)
  createdAt     DateTime              @default(now())

  user    User        @relation("UserAdjustments", fields: [userId], references: [id], onDelete: Cascade)
  account BankAccount @relation(fields: [accountId], references: [id])
  admin   User        @relation("AdminAdjustments", fields: [adminId], references: [id])
}

model DepositRequest {
  id                   String               @id @default(cuid())
  userId               String
  accountId            String?
  amountUsd            Decimal?             @db.Decimal(15, 2)
  bitcoinWalletAddress String?
  txHash               String?
  proofImage           String?              @db.Text
  proofNote            String?
  status               DepositRequestStatus @default(PENDING)
  reviewedBy           String?
  reviewNote           String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  user     User  @relation("UserDeposits", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("DepositReviewer", fields: [reviewedBy], references: [id])
}

model UserNotification {
  id             String   @id @default(cuid())
  userId         String
  type           String
  title          String
  message        String   @db.Text
  read           Boolean  @default(false)
  actorUserId    String?
  depositId      String?
  invitationId   String?
  jointAccountId String?
  approvalId        String?
  taxRefundId       String?
  loanApplicationId String?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TaxRefundVerification {
  id                          String                        @id @default(cuid())
  userId                      String                        @unique
  applicationNumber           String                        @unique
  fullLegalName               String
  dateOfBirth                 DateTime
  ssnEncrypted                String                        @db.Text
  ssnHash                     String
  phone                       String
  email                       String
  residentialAddress          String
  city                        String
  state                       String
  zipCode                     String
  employerName                String
  employerAddress             String
  jobTitle                    String
  annualIncome                Decimal                       @db.Decimal(15, 2)
  employmentStartDate         DateTime
  taxFilingStatus             String
  taxYear                     String
  adjustedGrossIncome         Decimal                       @db.Decimal(15, 2)
  federalTaxPaid              Decimal                       @db.Decimal(15, 2)
  taxRefundAmountExpected     Decimal                       @db.Decimal(15, 2)
  tinEncrypted                String                        @db.Text
  irsFilingConfirmationNumber String
  bankName                    String
  accountHolderName           String
  accountNumberEncrypted      String                        @db.Text
  routingNumberEncrypted      String                        @db.Text
  governmentId                String?                       @db.Text
  taxReturnDocument           String?                       @db.Text
  w2Form                      String?                       @db.Text
  proofOfAddress              String?                       @db.Text
  declarationAccepted         Boolean                       @default(false)
  status                      TaxRefundVerificationStatus   @default(PENDING)
  reviewedBy                  String?
  reviewNote                  String?
  adminNotes                  String?                       @db.Text
  createdAt                   DateTime                      @default(now())
  updatedAt                   DateTime                      @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer         User?             @relation("TaxRefundReviewer", fields: [reviewedBy], references: [id])
  loanApplications LoanApplication[]
}

model LoanProduct {
  id                    String          @id @default(cuid())
  slug                  String          @unique
  name                  String
  type                  LoanProductType
  description           String          @db.Text
  minAmount             Decimal         @db.Decimal(15, 2)
  maxAmount             Decimal         @db.Decimal(15, 2)
  interestRatePercent   Decimal         @db.Decimal(5, 2)
  repaymentMonthsMin    Int
  repaymentMonthsMax    Int
  eligibilityCriteria   String          @db.Text
  fastApproval          Boolean         @default(false)
  enabled               Boolean         @default(true)
  sortOrder             Int             @default(0)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  applications LoanApplication[]
}

model LoanApplication {
  id                    String                @id @default(cuid())
  applicationNumber     String                @unique
  userId                String
  productId             String
  taxVerificationId     String
  requestedAmount       Decimal               @db.Decimal(15, 2)
  loanPurpose           String
  monthlyIncome         Decimal               @db.Decimal(15, 2)
  employmentStatus      String
  supportingDocuments   String?               @db.Text
  status                LoanApplicationStatus @default(SUBMITTED)
  approvedAmount        Decimal?              @db.Decimal(15, 2)
  interestRatePercent   Decimal?              @db.Decimal(5, 2)
  repaymentMonths       Int?
  reviewNote            String?
  adminNotes            String?               @db.Text
  reviewedBy            String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  product         LoanProduct           @relation(fields: [productId], references: [id])
  taxVerification TaxRefundVerification @relation(fields: [taxVerificationId], references: [id])
  reviewer        User?                 @relation("LoanReviewer", fields: [reviewedBy], references: [id])
  userLoan        UserLoan?
}

model UserLoan {
  id                    String         @id @default(cuid())
  loanNumber            String         @unique
  userId                String
  applicationId         String         @unique
  productName           String
  approvedAmount        Decimal        @db.Decimal(15, 2)
  outstandingBalance    Decimal        @db.Decimal(15, 2)
  monthlyPayment        Decimal        @db.Decimal(15, 2)
  interestRatePercent   Decimal        @db.Decimal(5, 2)
  repaymentMonths       Int
  nextDueDate           DateTime?
  status                UserLoanStatus @default(ACTIVE)
  disbursedAt           DateTime?
  approvedAt            DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  application  LoanApplication @relation(fields: [applicationId], references: [id])
  repayments   LoanRepayment[]
}

model LoanRepayment {
  id        String   @id @default(cuid())
  loanId    String
  amount    Decimal  @db.Decimal(15, 2)
  paidAt    DateTime @default(now())
  note      String?

  loan UserLoan @relation(fields: [loanId], references: [id], onDelete: Cascade)
}

model JointAccount {
  id            String             @id @default(cuid())
  accountNumber String             @unique
  balance       Decimal            @default(0) @db.Decimal(15, 2)
  currency      String             @default("USD")
  status        JointAccountStatus @default(ACTIVE)
  ownershipType String             @default("JOINT_EQUAL")
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  members          JointAccountUser[]
  transactions     JointAccountTransaction[]
  investments      JointAccountInvestment[]
  investmentOrders JointAccountInvestmentOrder[]
  approvals        JointAccountApproval[]
  activityLogs     JointAccountActivityLog[]
  invitations      JointAccountInvitation[]
}

model JointAccountUser {
  id             String           @id @default(cuid())
  jointAccountId String
  userId         String
  role           JointAccountRole @default(CO_OWNER)
  createdAt      DateTime         @default(now())

  jointAccount JointAccount @relation(fields: [jointAccountId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jointAccountId, userId])
}

model JointAccountInvitation {
  id             String                @id @default(cuid())
  inviterId      String
  inviteeId      String?
  inviteeEmail   String
  inviteeName    String?
  inviteePhone   String?
  status         JointInvitationStatus @default(PENDING)
  expiresAt      DateTime
  jointAccountId String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  inviter      User          @relation("SentJointInvitations", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee      User?         @relation("ReceivedJointInvitations", fields: [inviteeId], references: [id], onDelete: SetNull)
  jointAccount JointAccount? @relation(fields: [jointAccountId], references: [id], onDelete: SetNull)
}

model JointAccountApproval {
  id             String              @id @default(cuid())
  jointAccountId String
  initiatedById  String
  approverId     String
  type           String
  amount         Decimal             @db.Decimal(15, 2)
  description    String
  payload        String              @db.Text
  status         JointApprovalStatus @default(PENDING)
  createdAt      DateTime            @default(now())
  approvedAt     DateTime?

  jointAccount JointAccount @relation(fields: [jointAccountId], references: [id], onDelete: Cascade)
  initiator    User         @relation("InitiatedApprovals", fields: [initiatedById], references: [id])
  approver     User         @relation("ApprovalRequests", fields: [approverId], references: [id])
}

model JointAccountTransaction {
  id             String            @id @default(cuid())
  jointAccountId String
  userId         String
  type           TransactionType
  amount         Decimal           @db.Decimal(15, 2)
  description    String
  status         TransactionStatus @default(COMPLETED)
  createdAt      DateTime          @default(now())

  jointAccount JointAccount @relation(fields: [jointAccountId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JointAccountInvestment {
  id             String   @id @default(cuid())
  jointAccountId String
  symbol         String
  name           String
  shares         Decimal  @db.Decimal(15, 6)
  avgPrice       Decimal  @db.Decimal(15, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  jointAccount JointAccount @relation(fields: [jointAccountId], references: [id], onDelete: Cascade)

  @@unique([jointAccountId, symbol])
}

model JointAccountInvestmentOrder {
  id              String   @id @default(cuid())
  jointAccountId  String
  userId          String
  symbol          String
  assetName       String
  amountUsd       Decimal  @db.Decimal(15, 2)
  shares          Decimal  @db.Decimal(15, 6)
  priceAtPurchase Decimal  @db.Decimal(15, 2)
  fee             Decimal  @default(0) @db.Decimal(15, 2)
  totalCost       Decimal  @db.Decimal(15, 2)
  status          String   @default("COMPLETED")
  createdAt       DateTime @default(now())

  jointAccount JointAccount @relation(fields: [jointAccountId], references: [id], onDelete: Cascade)
}

model JointAccountActivityLog {
  id             String   @id @default(cuid())
  jointAccountId String
  userId         String
  action         String
  details        String   @db.Text
  ipAddress      String?
  createdAt      DateTime @default(now())

  jointAccount JointAccount @relation(fields: [jointAccountId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WithdrawalRequest {
  id                   String                  @id @default(cuid())
  userId               String
  userNameSnapshot     String?
  accountId            String
  method               WithdrawalMethod        @default(CRYPTO_STABLECOIN)
  amountUsd            Decimal                 @db.Decimal(15, 2)
  assignedChargeAmount Decimal?                @db.Decimal(15, 2)
  destination          String                  @map("walletAddress")
  destinationExtra     String?
  note                 String?
  status               WithdrawalRequestStatus @default(PENDING)
  reviewedBy           String?
  reviewNote           String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  user          User                     @relation("UserWithdrawals", fields: [userId], references: [id], onDelete: Cascade)
  reviewer      User?                    @relation("WithdrawalReviewer", fields: [reviewedBy], references: [id])
  chargePayment WithdrawalChargePayment?
}

model UserWithdrawalCharge {
  id          String               @id @default(cuid())
  userId      String               @unique
  chargeType  WithdrawalChargeType @default(FIXED)
  amountUsd   Decimal              @db.Decimal(15, 2)
  percentage  Decimal?             @db.Decimal(5, 2)
  active      Boolean              @default(true)
  createdById String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdBy User @relation("WithdrawalChargeCreator", fields: [createdById], references: [id])
}

model WithdrawalChargePayment {
  id                  String                        @id @default(cuid())
  userId              String
  withdrawalRequestId String                        @unique
  amountUsd           Decimal                       @db.Decimal(15, 2)
  paymentMethod       String                        @default("BITCOIN")
  status              WithdrawalChargePaymentStatus @default(UNPAID)
  txHash              String?
  proofNote           String?
  proofImage          String?                       @db.Text
  reviewedBy          String?
  reviewNote          String?
  paidAt              DateTime?
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt

  user              User              @relation("UserChargePayments", fields: [userId], references: [id], onDelete: Cascade)
  withdrawalRequest WithdrawalRequest @relation(fields: [withdrawalRequestId], references: [id], onDelete: Cascade)
  reviewer          User?             @relation("ChargePaymentReviewer", fields: [reviewedBy], references: [id])
}

model UserProfitTax {
  id          String   @id @default(cuid())
  userId      String   @unique
  percentage  Decimal  @db.Decimal(5, 2)
  active      Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdBy User @relation("ProfitTaxCreator", fields: [createdById], references: [id])
}

model ProfitWithdrawalRequest {
  id                String                       @id @default(cuid())
  userId            String
  amountUsd         Decimal                      @db.Decimal(15, 2)
  assignedTaxAmount Decimal                      @db.Decimal(15, 2)
  taxPercentage     Decimal                      @db.Decimal(5, 2)
  status            ProfitWithdrawalRequestStatus @default(AWAITING_TAX_PAYMENT)
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt

  user       User             @relation("UserProfitWithdrawals", fields: [userId], references: [id], onDelete: Cascade)
  taxPayment ProfitTaxPayment?
}

model ProfitTaxPayment {
  id                        String                   @id @default(cuid())
  userId                    String
  profitWithdrawalRequestId String                   @unique
  amountUsd                 Decimal                  @db.Decimal(15, 2)
  paymentMethod             String                   @default("BITCOIN")
  status                    ProfitTaxPaymentStatus   @default(UNPAID)
  txHash                    String?
  proofNote                 String?
  proofImage                String?                  @db.Text
  reviewedBy                String?
  reviewNote                String?
  paidAt                    DateTime?
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt

  user                      User                    @relation("UserProfitTaxPayments", fields: [userId], references: [id], onDelete: Cascade)
  profitWithdrawalRequest   ProfitWithdrawalRequest @relation(fields: [profitWithdrawalRequestId], references: [id], onDelete: Cascade)
  reviewer                  User?                   @relation("ProfitTaxPaymentReviewer", fields: [reviewedBy], references: [id])
}

