# ── Gmail SMTP (all transactional email) ──
# 1. Enable 2-Step Verification on the Google account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Use the Gmail address + 16-character app password below (spaces are OK)
GMAIL_USER="your-account@gmail.com"
GMAIL_APP_PASSWORD="your-app-password-here"
EMAIL_FROM="BlackrockReserve <your-account@gmail.com>"
# Where contact-form alerts are sent (optional; falls back to ADMIN_EMAIL)
NOTIFY_EMAIL="admin@theblackrockreserve.com"

# Optional custom SMTP (if not using Gmail service preset)
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASSWORD=""

