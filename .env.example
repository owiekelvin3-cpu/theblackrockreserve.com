# ── Resend (production email — verification, sign-up, transactions, contact) ──
# 1. Create account: https://resend.com
# 2. Domains → Add Domain → blackrockreserve.site
# 3. Add the DNS records Resend shows (DKIM, SPF, etc.) at your domain registrar
# 4. Wait for "Verified" status, then create an API key
RESEND_API_KEY="re_xxxxxxxxxxxxxxxx"
EMAIL_FROM="BlackrockReserve <noreply@blackrockreserve.site>"
# Where contact-form alerts are sent (optional; falls back to ADMIN_EMAIL)
NOTIFY_EMAIL="admin@blackrockreserve.site"

# Gmail fallback (optional — local dev only if RESEND_API_KEY is not set)
GMAIL_USER=""
GMAIL_APP_PASSWORD=""

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Database (Supabase PostgreSQL)
# Pooled connection for the app (port 6543 + pgbouncer)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# Direct connection for Prisma migrations (port 5432, NOT the pooler)
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require"

# Site URL — MUST match your live domain exactly (no trailing slash)
# Local: http://localhost:3000
# Production: https://www.blackrockreserve.site
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Admin bootstrap (for npm run admin:create)
ADMIN_EMAIL="admin@blackrockreserve.site"
ADMIN_PASSWORD="change-me-in-production"
ADMIN_NAME="Platform Admin"

# Dev only — never set true in production
ADMIN_PASSWORDLESS="false"
