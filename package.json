{
  "name": "blackrock-reserve",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-start.mjs",
    "dev:clean": "npm run clean && node scripts/dev-start.mjs",
    "build": "npx prisma@5.22.0 generate && node scripts/generate-pwa-icons.mjs && next build",
    "db:migrate": "node scripts/apply-support-chat-schema.mjs && node scripts/apply-verification-badge-schema.mjs && node scripts/apply-deposit-proof-image.mjs && node scripts/apply-physical-cards-schema.mjs && node scripts/apply-notification-actor.mjs && node scripts/apply-account-freeze-schema.mjs && node scripts/apply-preferred-currency-schema.mjs && node scripts/apply-email-center-schema.mjs",
    "start": "next start",
    "lint": "next lint",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "db:push": "npx prisma@5.22.0 db push",
    "db:studio": "npx prisma@5.22.0 studio",
    "admin:create": "node scripts/create-admin.mjs",
    "cleanup:test-users": "node --env-file=.env scripts/cleanup-test-users.mjs",
    "seed:market-assets": "node scripts/seed-market-assets.mjs",
    "postinstall": "npx prisma@5.22.0 generate"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.469.0",
    "next": "14.2.35",
    "next-auth": "^4.24.14",
    "nodemailer": "^7.0.13",
    "qrcode": "^1.5.4",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.77.0",
    "react-icons": "^5.6.0",
    "recharts": "^3.8.1",
    "sharp": "^0.35.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitalets/google-translate-api": "^9.2.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prisma": "5.22.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
